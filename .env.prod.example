# ═══════════════════════════════════════════════════════════
# ZapFlow — Docker Compose Production Variables
# ═══════════════════════════════════════════════════════════
#
# Copie este arquivo para .env na RAIZ do projeto:
#   cp .env.prod.example .env
#
# ⚠️  O Docker Compose lê as variáveis do arquivo .env
#     no mesmo diretório do arquivo compose.
#     docker compose -f docker-compose.prod.yml up -d
#
# Gere senhas fortes:
#   openssl rand -base64 32   (para JWT_SECRET)
#   openssl rand -base64 16   (para POSTGRES_PASSWORD / REDIS_PASSWORD)
# ═══════════════════════════════════════════════

# ─── Caddy (Reverse Proxy / TLS) ────────────────
# Domínio público da aplicação (DNS deve apontar para o servidor)
CADDY_DOMAIN=app.zapflow.com
# Email para Let's Encrypt (notificações de certificado)
CADDY_EMAIL=admin@zapflow.com

# ─── Database ──────────────────────────────────
POSTGRES_USER=zapflow
POSTGRES_PASSWORD=CHANGE-ME-TO-A-STRONG-PASSWORD
POSTGRES_DB=zapflow

# ─── Redis ─────────────────────────────────────
REDIS_PASSWORD=CHANGE-ME-TO-A-STRONG-REDIS-PASSWORD

# ─── URLs Públicas ─────────────────────────────
# Domínio público do frontend (ex: https://app.zapflow.com)
FRONTEND_URL=https://app.zapflow.com
# Domínio público ou interno do backend (usado para webhooks da Evolution API)
# Se a Evolution API roda na mesma rede Docker: http://backend:3001
BACKEND_URL=https://api.zapflow.com

# ─── Database Backup ────────────────────────────
# Retenção de backups locais em dias (default: 30)
BACKUP_RETENTION_DAYS=30

# Horário do backup diário em UTC (default: 3:00 AM)
BACKUP_SCHEDULE_HOUR=3
BACKUP_SCHEDULE_MINUTE=0

# S3 (opcional — descomente no docker-compose.prod.yml para ativar)
# Necessário para backup off-site. Serviços compatíveis:
# AWS S3, Backblaze B2, Wasabi, Cloudflare R2, DigitalOcean Spaces
# S3_BUCKET=zapflow-backups
# S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
# S3_ACCESS_KEY=seu-access-key
# S3_SECRET_KEY=seu-secret-key

# Webhook para notificação de falha (opcional)
# Suporta Discord e Slack (formato de mensagem simples)
# BACKUP_NOTIFY_WEBHOOK=https://hooks.slack.com/services/xxx/yyy/zzz
