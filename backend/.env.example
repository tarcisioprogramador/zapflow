# ═══════════════════════════════════════════
# ZapFlow Backend — Production Environment
# ═══════════════════════════════════════════

NODE_ENV=production
PORT=3001
APP_NAME=ZapFlow

# Railway PostgreSQL (criado automaticamente)
DATABASE_URL=postgresql://user:password@host:5432/zapflow

# JWT — gere uma chave forte! Ex: openssl rand -hex 32
JWT_SECRET=troque-por-uma-chave-aleatoria-de-64-caracteres

# URLs do seu deploy
FRONTEND_URL=https://seu-app.vercel.app
BACKEND_URL=https://seu-backend.railway.app

# Mercado Pago (opcional)
# MP_ACCESS_TOKEN=APP_USR-...
# MP_PUBLIC_KEY=APP_USR-...

# Evolution API (opcional - WhatsApp real)
# EVOLUTION_API_URL=http://localhost:8080
# EVOLUTION_API_KEY=sua-chave

# IA (opcional - pelo menos uma)
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# GEMINI_API_KEY=AIza...

RATE_LIMIT_MAX=200
