# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zapflow?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"
# Em produção (Railway), use: https://app.zapflow.com.br

# WhatsApp (Evolution API or similar)
WHATSAPP_API_URL="https://your-whatsapp-api.com"
WHATSAPP_API_KEY="your-whatsapp-api-key"

# ─── Stripe (Payment Processing) ────────────────────────────
# 1. Crie sua conta em https://dashboard.stripe.com/register
# 2. Vá em: Developers > API keys
# 3. Copie as chaves abaixo
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# 4. Vá em: Developers > Webhooks > Add endpoint
#    URL: https://SEU-DOMINIO/api/webhook/stripe
#    Events: checkout.session.completed, invoice.payment_succeeded,
#            invoice.payment_failed, customer.subscription.deleted,
#            customer.subscription.updated
# 5. Copie o Signing Secret
STRIPE_WEBHOOK_SECRET="whsec_..."

# 6. Crie os produtos em Produtos > Criar produto
#    Ou rode: node scripts/setup-stripe.js
#    Copie os Price IDs gerados:
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_ENTERPRISE="price_..."

# ─── OpenAI (optional — fallback AI provider) ─────────────
OPENAI_API_KEY="your-openai-api-key"

# ─── App Name ──────────────────────────────────────────────
APP_NAME="ZapFlow"
