# ─── Servidor ──────────────────────────────
PORT=3001
NODE_ENV=production
APP_NAME="ZapFlow"
FRONTEND_URL="https://seudominio.com"
BACKEND_URL="https://api.seudominio.com"
RATE_LIMIT_MAX=100

# ─── Banco de Dados ────────────────────────
# Provider no schema.prisma deve ser "postgresql"
DATABASE_URL="postgresql://user:password@host:5432/zapflow"

# ─── Autenticação JWT ──────────────────────
JWT_SECRET="substitua-por-um-segredo-forte-aqui"
JWT_EXPIRES_IN="7d"

# ─── Mercado Pago ────────────────────────────
MP_ACCESS_TOKEN="APP_USR-..."
MP_PUBLIC_KEY="APP_USR-..."
MP_WEBHOOK_SECRET="seu-webhook-secret"
