generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth & Plans ───────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  password      String
  role          String    @default("ATTENDANT")
  plan          String    @default("FREE")
  avatar        String?
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  organization  Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?

  conversations  Conversation[]
  contacts       Contact[]
  campaigns      Campaign[]
  flows          Flow[]
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  plan      String   @default("FREE")
  logo      String?
  stripeCustomerId     String? @unique
  stripeSubscriptionId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  whatsappNumbers  WhatsAppNumber[]
  crmBoards  CrmBoard[]
  webhooks   Webhook[]
  knowledgeBaseItems  KnowledgeBaseItem[]
}

// ─── WhatsApp Integration ───────────────────────────────

model WhatsAppNumber {
  id              String          @id @default(uuid())
  number          String
  name            String
  status          String          @default("DISCONNECTED")
  instanceId      String?
  qrcode          String?
  trialExpiresAt  DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String

  conversations Conversation[]
}

// ─── Conversations & Messages ───────────────────────────

model Conversation {
  id        String   @id @default(uuid())
  status    String   @default("open")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  whatsappNumber   WhatsAppNumber @relation(fields: [whatsappNumberId], references: [id])
  whatsappNumberId String

  contact    Contact? @relation(fields: [contactId], references: [id])
  contactId  String?

  user    User? @relation(fields: [userId], references: [id])
  userId  String?

  messages  Message[]
  tags      ConversationTag[]
}

model Message {
  id        String      @id @default(uuid())
  content   String
  type      String      @default("TEXT")
  from      String
  to        String
  status    String      @default("SENT")
  mediaUrl  String?
  isFromBot Boolean     @default(false)
  createdAt DateTime    @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId String
}

model Tag {
  id    String @id @default(uuid())
  name  String
  color String @default("#6366f1")

  conversations ConversationTag[]
}

model ConversationTag {
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId String
  tag            Tag          @relation(fields: [tagId], references: [id])
  tagId          String

  @@id([conversationId, tagId])
}

// ─── CRM / Kanban ───────────────────────────────────────

model CrmBoard {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String

  stages  CrmStage[]
  cards   CrmCard[]
}

model CrmStage {
  id       String @id @default(uuid())
  name     String
  color    String @default("#6366f1")
  position Int    @default(0)

  board    CrmBoard @relation(fields: [boardId], references: [id])
  boardId  String

  cards CrmCard[]
}

model CrmCard {
  id          String   @id @default(uuid())
  title       String
  description String?
  value       Float?
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  board   CrmBoard @relation(fields: [boardId], references: [id])
  boardId String

  stage   CrmStage @relation(fields: [stageId], references: [id])
  stageId String

  contact   Contact? @relation(fields: [contactId], references: [id])
  contactId String?
}

model Contact {
  id        String   @id @default(uuid())
  name      String
  phone     String
  email     String?
  company   String?
  tags      String   @default("[]")
  notes     String?
  utmSource  String?
  utmMedium  String?
  utmCampaign String?
  adId       String?
  adTitle    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user    User? @relation(fields: [userId], references: [id])
  userId  String?

  conversations Conversation[]
  crmCards      CrmCard[]
}

// ─── Knowledge Base ──────────────────────────────────────

model KnowledgeBaseItem {
  id        String   @id @default(uuid())
  title     String
  content   String
  category  String   @default("Geral")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
}

// ─── Flows (Visual Builder) ─────────────────────────────

model Flow {
  id          String   @id @default(uuid())
  name        String
  description String?
  isActive    Boolean  @default(false)
  triggerType String   @default("keyword")
  triggerValue String?
  nodes       String   @default("[]")
  edges       String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User? @relation(fields: [userId], references: [id])
  userId  String?

  executions FlowExecution[]
}

model FlowExecution {
  id        String   @id @default(uuid())
  status    String   @default("running")
  context   String   @default("{}")
  startedAt DateTime @default(now())
  endedAt   DateTime?

  flow   Flow   @relation(fields: [flowId], references: [id])
  flowId String
}

// ─── Campaigns (Bulk Messages) ──────────────────────────

model Campaign {
  id          String         @id @default(uuid())
  name        String
  message     String
  mediaUrl    String?
  status      String         @default("DRAFT")
  scheduledAt DateTime?
  sentAt      DateTime?
  totalSent   Int            @default(0)
  totalFailed Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user    User? @relation(fields: [userId], references: [id])
  userId  String?

  contacts CampaignContact[]
}

model CampaignContact {
  id        String @id @default(uuid())
  phone     String
  name      String?
  status    String @default("pending")
  sentAt    DateTime?

  campaign   Campaign @relation(fields: [campaignId], references: [id])
  campaignId String
}

// ─── Webhooks ───────────────────────────────────────────

model Webhook {
  id        String   @id @default(uuid())
  name      String
  url       String
  events    String   @default("[]")
  secret    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
}

// ─── Remarketing ────────────────────────────────────────

model RemarketingSequence {
  id          String   @id @default(uuid())
  name        String
  description String?
  isActive    Boolean  @default(false)
  steps       String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  executions RemarketingExecution[]
}

model RemarketingExecution {
  id        String   @id @default(uuid())
  contactId String
  stepIndex Int      @default(0)
  status    String   @default("pending")
  nextRun   DateTime
  createdAt DateTime @default(now())

  sequence   RemarketingSequence @relation(fields: [sequenceId], references: [id])
  sequenceId String
}
