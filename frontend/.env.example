# ═══════════════════════════════════════════
# ZapFlow Frontend - Environment Variables
# ═══════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# API Base URL
# Used by frontend to communicate with the backend.
# In development, Vite's proxy handles this (see vite.config.ts).
# In production, set to your backend URL.
VITE_API_URL="/api"
